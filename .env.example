# Supabase settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# Optional role-based user lists
SUPABASE_PROGRAMADOR_EMAILS=dev@example.com
SUPABASE_ADMIN_EMAILS=admin@example.com
SUPABASE_SECRETARIA_EMAILS=secretaria@example.com
SUPABASE_TESOURARIA_EMAILS=tesouraria@example.com

# Local fallback admin
ADMIN_USER=admin
ADMIN_PASS=admin
